#!/bin/sh
# Glama build shim. Glama builds Python MCP servers with `uv sync` (which installs
# the `fable` console script into /app/.venv/bin) but then spawns bare `fable`,
# which is not on PATH -> "spawn fable ENOENT". Glama's generated image DOES put
# /app/node_modules/.bin on PATH and clones this repo into /app, so this committed
# shim is what `spawn fable` resolves to. It execs the real venv binary (falling
# back to `uv run`). Lets the Glama auto-build work with no dashboard changes.
if [ -x /app/.venv/bin/fable ]; then
  exec /app/.venv/bin/fable "$@"
fi
exec uv run --directory /app fable "$@"
