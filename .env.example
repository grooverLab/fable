# Copy to .env and fill in. fable loads this automatically (never overrides real env vars).
OPENROUTER_API_KEY=
# Free Gemma 3 27B on OpenRouter. Override if the free tier model changes.
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# Optional: requests per minute throttle for the card pass (free tier is strict).
OPENROUTER_RPM=15

# --- storage layout (all optional; sensible defaults under ~/.fable/) ---
# FABLE_HOME=~/.fable                # root for db, vault, checkpoints, config
# FABLE_VAULT=/Volumes/T7/fable-vault # put the vault on another drive
# FABLE_DB=~/.fable/fable.db          # index location
# FABLE_BACKUP_ROOTS=/path/a:/path/b  # extra dirs to read legacy backups from
